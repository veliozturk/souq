{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-api",
      "type": "shell",
      "command": "${env:HOME}/.dotnet/dotnet",
      "args": [
        "build",
        "${workspaceFolder}/api/Souq.Api.csproj",
        "-p:GenerateFullPaths=true",
        "-consoleloggerparameters:NoSummary"
      ],
      "options": {
        "env": {
          "DOTNET_ROOT": "${env:HOME}/.dotnet",
          "DOTNET_MULTILEVEL_LOOKUP": "0"
        }
      },
      "group": "build",
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    }
  ]
}
